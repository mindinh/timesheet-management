{
  "name": "timesheet-management",
  "version": "1.0.0",
  "description": "Timesheet Management Application",
  "dependencies": {
    "@cap-js/hana": "^2",
    "@sap/cds": "^9",
    "@sap/xssec": "^4",
    "exceljs": "^4.4.0",
    "express": "^4",
    "uuid": "^13.0.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@cap-js/cds-typer": "^0.38.0",
    "@cap-js/cds-types": "^0.15.0",
    "@cap-js/sqlite": "^2",
    "@sap/cds-dk": "^9",
    "@types/jest": "^30.0.0",
    "@types/node": "^25.0.3",
    "@types/uuid": "^10.0.0",
    "concurrently": "^9",
    "eslint": "^9",
    "eslint-config-prettier": "^10",
    "husky": "^9",
    "jest": "^30",
    "lint-staged": "^16",
    "prettier": "^3",
    "ts-jest": "^29",
    "ts-node": "^10",
    "tsx": "^4",
    "typescript": "^5"
  },
  "scripts": {
    "start": "cds-serve",
    "build:types": "cds-typer \"*\" --outputDirectory @cds-models",
    "watch:types": "cds-typer \"*\" --outputDirectory @cds-models",
    "types": "npm run build:types",
    "dev": "cds serve all --with-mocks",
    "deploy:db": "cds deploy --to sqlite:timesheet.db",
    "dev:all": "npm run deploy:db && concurrently -n BE,FE -c cyan,magenta \"npm run dev\" \"npm run dev --prefix app/timesheet-app\"",
    "test": "jest",
    "prepare": "husky"
  },
  "private": true,
  "cds": {
    "server": {
      "parsers": {
        "json": {
          "limit": "50mb"
        },
        "urlencoded": {
          "limit": "50mb",
          "extended": true
        }
      }
    },
    "watch": {
      "exclude": ["@cds-models", "*.db", "*.db-wal", "*.db-shm", "*.db-journal", "app"]
    },
    "requires": {
      "db": {
        "kind": "sqlite",
        "impl": "@cap-js/sqlite",
        "credentials": {
          "url": "timesheet.db"
        }
      },
      "auth": {
        "kind": "mocked",
        "users": {

          "max": {
            "password": "max",
            "roles": ["Admin"],
            "attr": { "email": ["admin@conarum.de"] }
          },
          "anna": {
            "password": "anna",
            "roles": ["TeamLead"],
            "attr": { "email": ["tl1@conarum.de"] }
          },
          "peter": {
            "password": "peter",
            "roles": ["TeamLead"],
            "attr": { "email": ["tl2@conarum.de"] }
          },
          "cuong": {
