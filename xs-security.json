{
  "xsappname": "timesheet-management",
  "tenant-mode": "dedicated",
  "description": "Conarum Timesheet Management Security",
  "scopes": [
    {
      "name": "$XSAPPNAME.Admin",
      "description": "Administrator — full access, auto-finish timesheets"
    },
    {
      "name": "$XSAPPNAME.TeamLead",
      "description": "Team Lead — approve/reopen timesheets for team members"
    },
    {
      "name": "$XSAPPNAME.Employee",
      "description": "Employee — log and submit own timesheets"
    }
  ],
  "attributes": [],
  "role-templates": [
    {
      "name": "Admin",
      "description": "Administrator with full access",
      "scope-references": [
        "$XSAPPNAME.Admin"
      ]
    },
    {
      "name": "TeamLead",
      "description": "Team Lead with approval access",
      "scope-references": [
        "$XSAPPNAME.TeamLead"
      ]
    },
    {
      "name": "Employee",
      "description": "Employee with timesheet logging access",
      "scope-references": [
        "$XSAPPNAME.Employee"
      ]
    }
  ],
  "role-collections": [
    {
      "name": "TimesheetAdmin",
      "description": "Timesheet Administrator — full access",
      "role-template-references": [
        "$XSAPPNAME.Admin"
      ]
    },
    {
      "name": "TimesheetTeamLead",
      "description": "Timesheet Team Lead — manage team timesheets",
      "role-template-references": [
        "$XSAPPNAME.TeamLead"
      ]
    },
    {
      "name": "TimesheetEmployee",
      "description": "Timesheet Employee — log and submit timesheets",
      "role-template-references": [
        "$XSAPPNAME.Employee"
      ]
    }
  ]
}
